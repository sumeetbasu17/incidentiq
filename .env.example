# ============================================
# IncidentIQ - Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (for LLM access - GPT-4o, Claude, etc.)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Tavily API Key (primary web search for incident research)
# Get yours at: https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx

# Serper API Key (backup/supplementary Google search)
# Get yours at: https://serper.dev (free tier: 2500 searches)
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith API Key (agent tracing & observability)
# Get yours at: https://smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxx
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=incidentiq

# OpenAI API Key (for embeddings - text-embedding-3-small)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Optional: Choose your preferred LLM model via OpenRouter
# Options: openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-2.0-flash-exp
OPENROUTER_MODEL=openai/gpt-4o
